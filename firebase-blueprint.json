{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user demographic and goal information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "height": { "type": "number", "description": "Height in cm" },
        "targetWeight": { "type": "number", "description": "Target weight in kg" },
        "currentWeight": { "type": "number", "description": "Current weight in kg" },
        "gender": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "DailyLog": {
      "title": "Daily Log",
      "description": "Holistic tracker for weight, mood, and energy.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "weight": { "type": "number" },
        "mood": { "type": "number", "description": "1 to 5 scale" },
        "energy": { "type": "number", "description": "1 to 5 scale" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "date", "createdAt"]
    },
    "MicroHabit": {
      "title": "Micro Habit",
      "description": "Daily habits generated by AI.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "completed": { "type": "boolean" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "title", "completed", "date", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profiles"
    },
    "/users/{userId}/logs/{logId}": {
      "schema": { "$ref": "#/entities/DailyLog" },
      "description": "Daily holistic logs"
    },
    "/users/{userId}/habits/{habitId}": {
      "schema": { "$ref": "#/entities/MicroHabit" },
      "description": "Daily micro habits"
    }
  }
}
