rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUserProfile() {
      return hasRequiredFields(['uid', 'email', 'createdAt']) &&
             request.resource.data.uid is string &&
             request.resource.data.email is string &&
             request.resource.data.createdAt is string;
    }

    function isValidDailyLog() {
      return hasRequiredFields(['uid', 'date', 'createdAt']) &&
             request.resource.data.uid is string &&
             request.resource.data.date is string &&
             request.resource.data.createdAt is string;
    }

    function isValidMicroHabit() {
      return hasRequiredFields(['uid', 'title', 'completed', 'date', 'createdAt']) &&
             request.resource.data.uid is string &&
             request.resource.data.title is string &&
             request.resource.data.completed is bool &&
             request.resource.data.date is string &&
             request.resource.data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile() && uidUnchanged();
      allow update: if isOwner(userId) && isValidUserProfile() && uidNotModified() && 
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(userId);
      
      match /logs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidDailyLog() && uidUnchanged();
        allow update: if isOwner(userId) && isValidDailyLog() && uidNotModified() &&
                      request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isOwner(userId);
      }
      
      match /habits/{habitId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMicroHabit() && uidUnchanged();
        allow update: if isOwner(userId) && isValidMicroHabit() && uidNotModified() &&
                      request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isOwner(userId);
      }
    }
  }
}
